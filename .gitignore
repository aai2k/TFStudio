# === SECRETS — never commit (license-signing private key, env, certs) ===
tools/license-signer/keys/
*.pem
*.key
.env
.env.*

# === Material data redistribution policy ===
# Shipped material data is native JSON (build/seed/library/*.catalog.json — factual
# n,k / Sellmeier data) plus the bundled Schott AGF and the CC0 refractiveindex.info
# mirror. No vendor .lm/.sub files are kept in or shipped from this repo; users
# import their own .lm/.sub or AGF catalogs at runtime, not here.
private-catalogs/
*.agf

node_modules/
dist/
*.log
app-debug.log
.DS_Store
Thumbs.db

# Temp/junk files — Claude Code CLI can produce these during edits on Windows
*,+
\(*

# Electron runtime data (generated at runtime, not source)
AppData/
# Machine-local app settings — app reads/writes its own copy in AppData and
# falls back to hardcoded defaults, so this file is not source.
settings.json

# Editor / AI-assistant tooling config
.vscode/
.claude/
*.swp

# Legacy user data
surfaces/
SurfaceExpertData/
tempsurfacedata.txt
ConvertSettings.txt
FitReport.txt
FitMetrics.txt
FitDeviations.txt
nul

.VSCodeCounter/

# WASM build artifact — generated by `npm run build:wasm` (needs Emscripten).
# Must be present before `npm run build` so electron-builder packages it.
src/wasm/tmm_kernel.wasm

# Bundled renderer output — generated by `npm run build:renderer` (tools/build-renderer.mjs)
build/app/
build/icons/
build/seed/

